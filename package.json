{
  "name": "oakwoodgolfclub-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "smoke:templates": "tsx scripts/smoke-autoresponse.ts",
    "smoke:smtp": "tsx --env-file=.env.local scripts/smoke-smtp-connect.ts",
    "smoke:send": "tsx --env-file=.env.local scripts/smoke-smtp-send.ts",
    "verify:cutover": "bash scripts/verify-b14-cutover.sh",
    "render:diagrams": "node docs/diagrams/render.mjs",
    "test:e2e": "playwright test",
    "test:e2e:prod": "E2E_BASE_URL=https://oakwoodgolfclub-website.vercel.app playwright test",
    "test:e2e:nightly": "E2E_BASE_URL=https://oakwoodgolfclub-website.vercel.app E2E_THROTTLE_MS=10000 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "node scripts/lighthouse.mjs",
    "lighthouse:quick": "node scripts/lighthouse.mjs --quick",
    "lighthouse:desktop": "node scripts/lighthouse.mjs --quick --profile=desktop",
    "lighthouse:mobile": "node scripts/lighthouse.mjs --quick --profile=mobile-4g",
    "lighthouse:slow": "node scripts/lighthouse.mjs --quick --profile=mobile-slow"
  },
  "dependencies": {
    "@friendlycaptcha/sdk": "1.0.0",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "gray-matter": "4.0.3",
    "lucide-react": "1.8.0",
    "marked": "18.0.2",
    "next": "16.2.6",
    "nodemailer": "8.0.5",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sanitize-html": "2.17.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.6.0",
    "@types/nodemailer": "8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "lighthouse": "13.0.3",
    "playwright": "1.59.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
